# -----------------------------------------------------------------------
#
#  Tokiwa Software GmbH, Germany
#
#  Source code of Fuzion webserver feature runner
#
# -----------------------------------------------------------------------

module runner is

  # maximum bytes to read from process
  #
  max_output_bytes => 1E5

  # maximum time to wait for process to finish
  #
  max_wait_time    => time.duration.s 30

  # compile and run some code
  #
  run_code(
    # the Session used for sending back results
    s Session,
    # the actual code
    code String,
    # the id of where the results belong in the html
    results_to String,
    # true execute, false analyze for effects
    normal bool) =>

    # NYI read_lines, send intermediate results
    args :=
      if normal
        ["-oLogLevel=FATAL", "flang@jenkins.tokiwa.software", "timeout", "--preserve-status", "--signal=15",
         "--kill-after=22s", "20s", "bwrap", "--ro-bind", "/", "/", "--dev-bind", "/dev", "/dev", "--unshare-all",
         "--clearenv", "--setenv", "PATH", "/run/current-system/sw/bin:/etc/profiles/per-user/flang/bin",
         "fuzion/build/bin/fz", "-"]
      else
        ["-oLogLevel=FATAL", "flang@jenkins.tokiwa.software", "timeout", "--preserve-status", "--signal=15",
         "--kill-after=22s", "20s", "bwrap", "--ro-bind", "/", "/", "--dev-bind", "/dev", "/dev", "--unshare-all",
         "--clearenv", "--setenv", "PATH", "/run/current-system/sw/bin:/etc/profiles/per-user/flang/bin",
         "fuzion/build/bin/fz", "-effects", "-"]

    s.send_event "pushElementContents" results_to "starting job ..."

    (os.process.start "ssh" args
      .bind p->

        # write code to stdin
        _ := p.write_string code .or_panic

        lm : mutate is

        _ := (concur.thread_pool 2 ()->

          res := concur.atomic String .new ""

          add_to_res(str String) =>
            _ := res.update (String->String) o->"$(o)$(if o.is_empty then "" else "\n")$(str)"
            s.send_event "pushElementContents" results_to res.read


          fout := concur.thread_pool.env.submit _ ()->
            fuzion.runtime.fault
              .try ()->
                lm ! ()->
                  p.with_out unit lm ()->
                    while match io.buffered lm .read_line
                      io.end_of_file => false
                      l String => add_to_res l; true
              .catch e->
                logger.log $e

          ferr := concur.thread_pool.env.submit _ ()->
            fuzion.runtime.fault
              .try ()->
                lm ! ()->
                  p.with_err unit lm ()->
                    while match io.buffered lm .read_line
                      io.end_of_file => false
                      l String => add_to_res "stderr: $(l)"; true
              .catch e->
                logger.log $e

          p.wait max_wait_time
           .bind _->
            _ := fout.get
            _ := ferr.get).or_panic

        _ := p.send_signal os.signals.kill).or_panic


  # helper feature
  #
  module run(s Session, form_data lock_free.Map String String) unit =>
    run_code s form_data["code"].or_panic form_data["resultsTo"].or_panic true

  # helper feature
  #
  module runeff(s Session, form_data lock_free.Map String String) unit =>
    run_code s form_data["code"].or_panic form_data["resultsTo"].or_panic false
